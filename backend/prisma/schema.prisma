generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id         String   @id @default(cuid())
  code       String   @unique
  hostName   String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  questions  Question[]
  candidates Candidate[]
  players    Player[]
  votes      Vote[]
}

model Question {
  id      String @id @default(cuid())
  text    String
  order   Int

  roomId  String
  room    Room   @relation(fields: [roomId], references: [id])

  votes   Vote[]
}

model Candidate {
  id      String @id @default(cuid())
  name    String

  roomId  String
  room    Room   @relation(fields: [roomId], references: [id])
}

model Player {
  id      String @id @default(cuid())
  name    String

  roomId  String
  room    Room   @relation(fields: [roomId], references: [id])

  votes   Vote[]
}

model Vote {
  id          String @id @default(cuid())
  targetName  String

  roomId      String
  questionId  String
  voterId     String

  room        Room     @relation(fields: [roomId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])
  voter       Player   @relation(fields: [voterId], references: [id])

  @@unique([questionId, voterId])
}
