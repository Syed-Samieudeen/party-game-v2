generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Room {
  id          String   @id @default(cuid())
  code        String   @unique
  hostName    String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  questions   Question[]
  candidates  Candidate[]
  players     Player[]
  votes       Vote[]
}

model Question {
  id        String   @id @default(cuid())
  text      String
  order     Int
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  votes     Vote[]
}

model Candidate {
  id      String @id @default(cuid())
  name    String
  roomId  String
  room    Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Player {
  id      String @id @default(cuid())
  name    String
  roomId  String
  room    Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  votes   Vote[]
}

model Vote {
  id          String   @id @default(cuid())

  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  voterId     String
  voter       Player   @relation(fields: [voterId], references: [id], onDelete: Cascade)

  targetName  String

  createdAt   DateTime @default(now())

  @@unique([questionId, voterId])
}
